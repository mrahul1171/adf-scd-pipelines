{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name"
		},
		"LS_REST_Countries": {
			"type": "string"
		},
		"LS_ADLS_Raw": {
			"type": "string"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "[concat(parameters('factoryName'), '/PL_Copy_Countries_ByName_To_ADLS')]",
			"type": "Microsoft.DataFactory/factories/pipelines",
			"apiVersion": "2018-06-01",
			"properties": {
				"activities": [
					{
						"name": "FE_Countries",
						"type": "ForEach",
						"dependsOn": [],
						"userProperties": [],
						"typeProperties": {
							"items": {
								"value": "@pipeline().parameters.CountryList",
								"type": "Expression"
							},
							"isSequential": true,
							"activities": [
								{
									"name": "CP_Country_JSON",
									"type": "Copy",
									"dependsOn": [],
									"policy": {
										"timeout": "0.12:00:00",
										"retry": 0,
										"retryIntervalInSeconds": 30,
										"secureOutput": false,
										"secureInput": false
									},
									"userProperties": [],
									"typeProperties": {
										"source": {
											"type": "RestSource",
											"httpRequestTimeout": "00:01:40",
											"requestInterval": "00.00:00:00.010",
											"requestMethod": "GET",
											"paginationRules": {
												"supportRFC5988": "true"
											}
										},
										"sink": {
											"type": "JsonSink",
											"storeSettings": {
												"type": "AzureBlobFSWriteSettings"
											},
											"formatSettings": {
												"type": "JsonWriteSettings"
											}
										},
										"enableStaging": false
									},
									"inputs": [
										{
											"referenceName": "DS_REST_Country_ByName",
											"type": "DatasetReference",
											"parameters": {
												"CountryName": {
													"value": "@item().lookup",
													"type": "Expression"
												},
												"ApiKey": {
													"value": "@pipeline().parameters.ApiKey",
													"type": "Expression"
												}
											}
										}
									],
									"outputs": [
										{
											"referenceName": "DS_ADLS_Country_JSON",
											"type": "DatasetReference",
											"parameters": {
												"FileName": {
													"value": "@item().file",
													"type": "Expression"
												}
											}
										}
									]
								}
							]
						}
					}
				],
				"parameters": {
					"ApiKey": {
						"type": "string",
						"defaultValue": "rc_live_89b0549fc51240de893ec9855404d51a"
					},
					"CountryList": {
						"type": "string",
						"defaultValue": [
							{
								"lookup": "India",
								"file": "india"
							},
							{
								"lookup": "United States",
								"file": "us"
							},
							{
								"lookup": "United Kingdom",
								"file": "uk"
							},
							{
								"lookup": "China",
								"file": "china"
							},
							{
								"lookup": "Russia",
								"file": "russia"
							}
						]
					}
				},
				"annotations": []
			},
			"dependsOn": [
				"[concat(variables('factoryId'), '/datasets/DS_REST_Country_ByName')]",
				"[concat(variables('factoryId'), '/datasets/DS_ADLS_Country_JSON')]"
			]
		},
		{
			"name": "[concat(parameters('factoryName'), '/DS_REST_Country_ByName')]",
			"type": "Microsoft.DataFactory/factories/datasets",
			"apiVersion": "2018-06-01",
			"properties": {
				"linkedServiceName": {
					"referenceName": "[parameters('LS_REST_Countries')]",
					"type": "LinkedServiceReference"
				},
				"parameters": {
					"CountryName": {
						"type": "string"
					},
					"ApiKey": {
						"type": "string",
						"defaultValue": "rc_live_89b0549fc51240de893ec9855404d51a"
					}
				},
				"annotations": [],
				"type": "RestResource",
				"typeProperties": {
					"relativeUrl": {
						"value": "@concat('v5/names.common/', replace(dataset().CountryName, ' ', '%20'), '?api-key=', dataset().ApiKey)",
						"type": "Expression"
					}
				},
				"schema": []
			},
			"dependsOn": []
		},
		{
			"name": "[concat(parameters('factoryName'), '/DS_ADLS_Country_JSON')]",
			"type": "Microsoft.DataFactory/factories/datasets",
			"apiVersion": "2018-06-01",
			"properties": {
				"linkedServiceName": {
					"referenceName": "[parameters('LS_ADLS_Raw')]",
					"type": "LinkedServiceReference"
				},
				"parameters": {
					"FileName": {
						"type": "string"
					}
				},
				"annotations": [],
				"type": "Json",
				"typeProperties": {
					"location": {
						"type": "AzureBlobFSLocation",
						"fileName": {
							"value": "@concat(dataset().FileName, '.json')",
							"type": "Expression"
						},
						"folderPath": "countries_by_name",
						"fileSystem": "raw"
					}
				},
				"schema": {}
			},
			"dependsOn": []
		}
	]
}