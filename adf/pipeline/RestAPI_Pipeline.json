{
	"name": "RestAPI_Pipeline",
	"properties": {
		"activities": [
			{
				"name": "Copy RESTAPI",
				"type": "Copy",
				"dependsOn": [],
				"policy": {
					"timeout": "0.12:00:00",
					"retry": 0,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"source": {
						"type": "RestSource",
						"httpRequestTimeout": "00:01:40",
						"requestInterval": "00.00:00:00.010",
						"requestMethod": "GET",
						"paginationRules": {
							"supportRFC5988": "true"
						}
					},
					"sink": {
						"type": "ParquetSink",
						"storeSettings": {
							"type": "AzureBlobFSWriteSettings"
						},
						"formatSettings": {
							"type": "ParquetWriteSettings"
						}
					},
					"enableStaging": false
				},
				"inputs": [
					{
						"referenceName": "DS_REST_Countries",
						"type": "DatasetReference",
						"parameters": {
							"relativeUrl": {
								"value": "https://restcountries.com/v3.1/all\n",
								"type": "Expression"
							}
						}
					}
				],
				"outputs": [
					{
						"referenceName": "DS_Parquet_Countries",
						"type": "DatasetReference",
						"parameters": {
							"fileName": "restAPI_1"
						}
					}
				]
			}
		],
		"annotations": []
	}
}